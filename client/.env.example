# In local dev you can leave this unset - Vite proxies /api -> http://localhost:5000.
#
# In production (Vercel), set this to your deployed backend origin + "/api":
#   VITE_API_URL=https://attendify-api.onrender.com/api
#
# This value is baked into the JS bundle at BUILD time, so you must redeploy
# the frontend if you change it.
# VITE_API_URL=
