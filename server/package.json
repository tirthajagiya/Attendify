{
  "name": "attendify-server",
  "version": "1.0.0",
  "description": "Attendify backend - JWT auth + QR-based attendance API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "cross-env DISABLE_V8_COMPILE_CACHE=1 nodemon --watch src --ext ts --delay 1500ms --signal SIGINT --exec \"ts-node --transpile-only\" src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "cross-env DISABLE_V8_COMPILE_CACHE=1 ts-node --transpile-only src/utils/seed.ts"
  },
  "keywords": ["attendance", "qr-code", "jwt", "express", "mongodb"],
  "license": "MIT",
  "engines": {
    "node": ">=18.18.0 <23"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "qrcode": "^1.5.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.10",
    "@types/qrcode": "^1.5.5",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}
