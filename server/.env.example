# =========================================================================
# Local development - copy this file to `.env` and edit the values below.
# =========================================================================

# Server
PORT=5000
NODE_ENV=development

# Database
# For local Mongo: mongodb://127.0.0.1:27017/attendify
# For Atlas:      mongodb+srv://<user>:<URL-ENCODED-password>@cluster.mongodb.net/attendify?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/attendify

# Auth - replace JWT_SECRET with a long random string before deploying.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Allowed frontend origins (comma-separated). Add your Vercel URL in production.
# Example: CLIENT_ORIGIN=http://localhost:5173,https://attendify.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# QR session: how long an attendance session stays alive without manual close
# is not bounded - QR_SESSION_TTL is unused by the new rotating-token flow
# but kept for forward compatibility.
QR_SESSION_TTL=300
